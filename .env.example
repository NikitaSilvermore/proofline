# Proofline environment (BUILD_SPEC.md §9). Copy to .env.local and fill in.
# NEXT_PUBLIC_* values are exposed to the browser (safe: anon key + URL).

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server only — never expose to the browser

# Messaging rail — which "postman" sends intake/check-in/nudge messages.
# "log" (default) sends nothing external, just records the intent. Set to
# "close", "ghl", or "resend" to go live.
MESSAGING_PROVIDER=log
MESSAGING_CHANNEL=email           # email | sms | both (used by the Close provider)

# Close CRM (close.com) — CRM + sender (current plan)
CLOSE_API_KEY=                    # Close API key (Basic auth)
CLOSE_SENDER=                     # connected sending identity, e.g. "NLS <hello@nls.com>"
CLOSE_SMS_NUMBER=                 # your Close SMS number, e.g. "+15551234567" (for sms/both)
CLOSE_SIGNING_KEY=                # Close webhook signature key (verifies /api/webhooks/close)
CLOSE_WEBHOOK_SECRET=             # optional shared secret for manually testing the webhook

# GHL (GoHighLevel) — legacy rail, kept for reference
GHL_API_KEY=
GHL_WEBHOOK_SECRET=               # verify inbound enrolment webhook (/api/webhooks/ghl)
GHL_INBOUND_WEBHOOK_URL=          # GHL workflow inbound URL we POST sends to (when MESSAGING_PROVIDER=ghl)

# Resend (fallback rail) — used when MESSAGING_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM=                      # e.g. "NLS Mentorship <hello@yourdomain.com>"

# Vercel Cron
CRON_SECRET=                      # protect /api/cron/weekly

# App
APP_BASE_URL=http://localhost:3000
